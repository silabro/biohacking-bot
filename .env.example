# ──────────────────────────────────────────────
# Silabro Biohacking Bot — Environment Variables
# Copy this file to .env and fill in real values.
# ──────────────────────────────────────────────

# ── Telegram ──
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# ── Google Gemini AI ──
GEMINI_API_KEY=your-gemini-api-key-here

# ── PostgreSQL ──
POSTGRES_USER=silabro
POSTGRES_PASSWORD=silabro_secret
POSTGRES_DB=silabro
DATABASE_URL=postgresql+asyncpg://silabro:silabro_secret@db:5432/silabro

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── Application-Level Encryption (MultiFernet) ──
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Multiple keys separated by comma for key rotation support.
FERNET_KEYS=key1-base64,key2-base64

# ── Logging ──
LOG_LEVEL=INFO
